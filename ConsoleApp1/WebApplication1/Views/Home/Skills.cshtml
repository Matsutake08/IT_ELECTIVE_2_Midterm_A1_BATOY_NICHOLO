@{
    ViewData["Title"] = "Skills";
}

<section class="py-5">
    <h2 class="display-6 fw-bold text-center text-dark mb-5">Skills</h2>
    <div class="row g-4">
        <div class="col-md-6 col-lg-3">
            <div class="card h-100 shadow-sm border-0 bg-white p-3">
                <div class="card-body">
                    <h5 class="card-title fw-bold text-dark mb-3">Programming Languages</h5>
                    <ul class="list-unstyled text-muted lh-lg">
                        <li>C#</li>
                        <li>Java</li>
                        <li>Python</li>
                    </ul>
                </div>
            </div>
        </div>
        <div class="col-md-6 col-lg-3">
            <div class="card h-100 shadow-sm border-0 bg-white p-3">
                <div class="card-body">
                    <h5 class="card-title fw-bold text-dark mb-3">Web Technologies</h5>
                    <ul class="list-unstyled text-muted lh-lg">
                        <li>HTML</li>
                        <li>CSS</li>
                        <li>Bootstrap</li>
                        <li>ASP.NET Core MVC</li>
                    </ul>
                </div>
            </div>
        </div>
        <div class="col-md-6 col-lg-3">
            <div class="card h-100 shadow-sm border-0 bg-white p-3">
                <div class="card-body">
                    <h5 class="card-title fw-bold text-dark mb-3">Databases</h5>
                    <ul class="list-unstyled text-muted lh-lg">
                        <li>Microsoft Access</li>
                    </ul>
                </div>
            </div>
        </div>
        <div class="col-md-6 col-lg-3">
            <div class="card h-100 shadow-sm border-0 bg-white p-3">
                <div class="card-body">
                    <h5 class="card-title fw-bold text-dark mb-3">Development Tools</h5>
                    <ul class="list-unstyled text-muted lh-lg">
                        <li>Visual Studio</li>
                        <li>PyCharm</li>
                        <li>NetBeans</li>
                        <li>Git</li>
                        <li>GitHub</li>
                    </ul>
                </div>
            </div>
        </div>
    </div>
</section>