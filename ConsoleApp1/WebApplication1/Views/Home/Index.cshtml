                    <p class="text-muted small mb-1">C#</p>
                    <p class="text-muted small mb-1">Java</p>
                    <p class="text-muted small mb-1">Python</p>
                </div>
            </div>
            <div class="col-md-3">
                <div class="skill-card">
                    <h6 class="fw-bold mb-3">Web<br>Technologies</h6>
                    <p class="text-muted small mb-1">HTML</p>
                    <p class="text-muted small mb-1">CSS</p>
                    <p class="text-muted small mb-1">Bootstrap</p>
                    <p class="text-muted small mb-1">ASP.NET Core MVC</p>
                </div>
            </div>
            <div class="col-md-3">
                <div class="skill-card">
                    <h6 class="fw-bold mb-3">Databases<br>&nbsp;</h6>
                    <p class="text-muted small mb-1">Microsoft Access</p>
                </div>
            </div>
            <div class="col-md-3">
                <div class="skill-card">
                    <h6 class="fw-bold mb-3">Development<br>Tools</h6>
