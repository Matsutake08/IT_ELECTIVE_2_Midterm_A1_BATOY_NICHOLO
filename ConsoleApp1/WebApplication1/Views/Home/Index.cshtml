                        <tr><td class="fw-bold">GitHub:</td><td><a href="https://github.com/Matsutake08" class="text-decoration-none">github.com/Matsutake08</a></td></tr>
                        <tr><td class="fw-bold">LinkedIn:</td><td class="text-muted">linkedin.com</td></tr>
                        <tr><td class="fw-bold">Facebook:</td><td><a href="https://facebook.com/nicholojohn8" class="text-decoration-none">facebook.com/nicholojohn8</a></td></tr>
