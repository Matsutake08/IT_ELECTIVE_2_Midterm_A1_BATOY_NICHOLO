@{
    ViewData["Title"] = "Home";
}

<section class="py-5 my-5 d-flex align-items-center min-vh-75">
    <div class="row align-items-center flex-column-reverse flex-md-row">
        <div class="col-md-7 text-center text-md-start">
            <h1 class="display-3 fw-bold text-dark">Nicholo John L. Batoy</h1>
            <h3 class="text-secondary mb-3">BSIT Undergrad</h3>
            <p class="lead text-muted mb-4">
                Hi, I'm Nicholo John L. Batoy, a BSIT student at Lyceum of Alabang with a passion for technology and continuous learning. As an aspiring IT professional, I love sharpening my strategic thinking through developing applications, exploring software systems, and building responsive web solutions.
            </p>
            <div class="d-grid d-sm-flex gap-3 justify-content-center justify-content-md-start">
                <a asp-controller="Home" asp-action="Projects" class="btn btn-primary btn-sm px-4 py-2">View Projects</a>
                <a asp-controller="Home" asp-action="Contact" class="btn btn-outline-secondary btn-sm px-4 py-2">Contact Me</a>
            </div>
        </div>
        <div class="col-md-5 text-center mb-4 mb-md-0">
            <img src="~/images/my-photo.png" class="img-fluid rounded-circle shadow-lg border border-4 border-light" alt="Nicholo's Photo" style="max-width: 280px; aspect-ratio: 1/1; object-fit: cover;" />
        </div>
    </div>
</section>