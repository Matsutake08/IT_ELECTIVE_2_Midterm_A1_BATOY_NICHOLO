            <div class="col-md-4">
                <div class="project-card">
                    <i class="bi bi-github" style="font-size: 6rem;"></i>
                    <h6 class="fw-bold mt-3" style="font-size: 0.9rem;">BSIT31E1 PRELIM A3_NicholoBatoy</h6>
                    <p class="text-muted small">A structured code solution emphasizing edge-case troubleshooting parameters.</p>
                    <p class="small fw-bold mb-2">Technologies: C#</p>
                    <button class="btn btn-primary btn-sm px-4">View Details</button>
                </div>
            </div>
        </div>
