<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Portfolio</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />

    <style>
            html, body {
                margin: 0 !important;
                padding: 0 !important;
                width: 100% !important;
                min-height: 100vh !important;
                font-family: 'Segoe UI', Arial, sans-serif !important;
                background-color: #f8f9fa !important;
            }

            .portfolio-container {
                display: flex !important;
                width: 100% !important;
                min-height: 100vh !important;
            }

            .sidebar-panel {
                background-color: #212529 !important;
                color: #fff !important;
                padding: 1.5rem !important;
                flex-shrink: 0 !important;
                z-index: 1050 !important;
            }

            .nav-link:hover {
                background-color: rgba(255, 255, 255, 0.1) !important;
                color: #0d6efd !important;
            }

            @@media (min-width: 992px) {
                .portfolio-container {
                    display: flex !important;
                    flex-direction: row !important;
                }

                .sidebar-panel {
                    width: 280px !important;
                    position: fixed !important;
                    top: 0;
                    bottom: 0;
                    left: 0;
                    height: 100vh !important;
                    overflow-y: auto !important;
                    display: block !important;
                }

                .content-viewport {
                    margin-left: 280px !important;
                    flex-grow: 1 !important;
                    width: calc(100% - 280px) !important;
                }

                .sidebar-brand {
                    display: block !important;
                    color: #0d6efd !important;
                    font-weight: 700 !important;
                    margin-bottom: 1.5rem !important;
                }

                .mobile-nav-header {
                    display: none !important;
                }

                .sidebar-menu-links {
                    display: block !important;
                }
            }

            @@media (max-width: 991.98px) {
                .portfolio-container {
                    display: block !important;
                    flex-direction: column !important;
                    width: 100% !important;
                }

                .sidebar-panel {
                    width: 100% !important;
                    position: relative !important;
                    height: auto !important;
                    display: block !important;
                }

                .content-viewport {
                    margin-left: 0 !important;
                    width: 100% !important;
                    display: block !important;
                }

                .sidebar-brand {
                    display: none !important;
                }

                .mobile-nav-header {
                    display: flex !important;
                    justify-content: space-between !important;
                    align-items: center !important;
                    width: 100% !important;
                }

                .sidebar-menu-links.collapse:not(.show) {
                    display: none !important;
                }

                .sidebar-menu-links.collapse.show {
                    display: block !important;
                }
            }
    </style>
</head>
<body>
    <div class="portfolio-container">
        <nav class="sidebar-panel">
            <h3 class="sidebar-brand">Portfolio</h3>

            <div class="mobile-nav-header">
                <h4 class="m-0 text-primary fw-bold">Portfolio</h4>
                <button class="btn btn-outline-light btn-sm" type="button" data-bs-toggle="collapse" data-bs-target="#sidebarMenu">
                    <i class="bi bi-list fs-4"></i>
                </button>
            </div>

            <div class="collapse d-lg-block sidebar-menu-links" id="sidebarMenu">
                <ul class="nav flex-column gap-2 mt-3 mt-lg-0">
                    <li class="nav-item">
                        <a class="nav-link text-white py-2 px-3 rounded d-flex align-items-center" asp-area="" asp-controller="Home" asp-action="Index">
                            <i class="bi bi-house me-3 fs-5"></i> Home
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link text-white py-2 px-3 rounded d-flex align-items-center" asp-area="" asp-controller="Home" asp-action="About">
                            <i class="bi bi-person me-3 fs-5"></i> About Me
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link text-white py-2 px-3 rounded d-flex align-items-center" asp-area="" asp-controller="Home" asp-action="Skills">
                            <i class="bi bi-code-slash me-3 fs-5"></i> Skills
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link text-white py-2 px-3 rounded d-flex align-items-center" asp-area="" asp-controller="Home" asp-action="Projects">
                            <i class="bi bi-folder me-3 fs-5"></i> Projects
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link text-white py-2 px-3 rounded d-flex align-items-center" asp-area="" asp-controller="Home" asp-action="Contact">
                            <i class="bi bi-envelope me-3 fs-5"></i> Contact
                        </a>
                    </li>
                </ul>
            </div>
        </nav>

        <main class="content-viewport p-4">
            @RenderBody()
        </main>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>

    <script>
            function handleMenuResponsiveState() {
                const menu = document.getElementById('sidebarMenu');
                if (window.innerWidth >= 992) {
                    menu.classList.add('show');
                } else {
                    menu.classList.remove('show');
                }
            }
            document.addEventListener("DOMContentLoaded", handleMenuResponsiveState);
            window.addEventListener("resize", handleMenuResponsiveState);
    </script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>