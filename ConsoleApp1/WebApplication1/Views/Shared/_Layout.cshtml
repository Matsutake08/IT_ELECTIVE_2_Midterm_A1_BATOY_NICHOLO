<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Portfolio</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>

    <div class="container-fluid">
        <div class="row">
            <nav id="sidebarMenu" class="col-md-3 col-lg-2 d-md-block bg-dark sidebar collapse position-fixed start-0 top-0 bottom-0 text-white p-3 z-1">
                <div class="position-sticky pt-3">
                    <h4 class="text-center mb-4 text-primary">Portfolio</h4>
                    <hr />
                    <ul class="nav flex-column gap-2">
                        <li class="nav-item">
                            <a class="nav-link text-white active" href="#home"><i class="bi bi-house-door me-2"></i> Home</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-white" href="#about"><i class="bi bi-person me-2"></i> About Me</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-white" href="#skills"><i class="bi bi-code-slash me-2"></i> Skills</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-white" href="#projects"><i class="bi bi-briefcase me-2"></i> Projects</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-white" href="#contact"><i class="bi bi-envelope me-2"></i> Contact</a>
                        </li>
                    </ul>
                </div>
            </nav>

            <header class="navbar navbar-dark sticky-top bg-dark flex-md-nowrap p-0 shadow d-md-none">
                <a class="navbar-brand col-md-3 col-lg-2 me-0 px-3 fs-6" href="#">My Portfolio</a>
                <button class="navbar-toggler position-absolute d-md-none collapsed end-0 m-2" type="button" data-bs-toggle="collapse" data-bs-target="#sidebarMenu" aria-controls="sidebarMenu" aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
            </header>

            <main class="col-md-9 ms-sm-auto col-lg-10 px-md-4 pt-4 offset-md-3 offset-lg-2">
                @RenderBody()

                <footer class="text-center my-5 pt-5 text-muted border-top">
                    &copy; 2026 - IT ELECTIVE 2 Portfolio Assignment
                </footer>
            </main>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>